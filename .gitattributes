# Auto detect text files and normalize line endings
* text=auto eol=lf

# Explicitly declare text files
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.html text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.webp binary
*.ico  binary
