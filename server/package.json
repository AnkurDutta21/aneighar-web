{
  "name": "aneighar-server",
  "version": "1.0.0",
  "description": "Anei Ghar PG Rental Platform — Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --runInBand --detectOpenHandles --forceExit",
    "lint": "eslint . --ext .js"
  },
  "keywords": ["pg", "rental", "node", "express", "mongodb"],
  "author": "AnkurDutta21",
  "license": "ISC",
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterFramework": [],
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "services/**/*.js",
      "models/**/*.js",
      "middleware/**/*.js"
    ]
  }
}
